<main class='exchange-page'>
  <div class='exchange-overlay'></div>

  <section class='exchange-shell container'>
    <div class='exchange-hero'>
      <div class='brand-panel'>
        <%= image_tag 'logo.png', class: 'brand-logo img-fluid' %>

        <div class='hero-copy'>
          <p class='eyebrow'>Conversor de moedas</p>
          <h1>Converta valores com clareza e rapidez.</h1>
          <p class='hero-description'>
            Simule cotações internacionais em uma experiência simples, direta e elegante.
          </p>
        </div>
      </div>

      <%= render 'exchange_box' %>
    </div>
  </section>
</main>
